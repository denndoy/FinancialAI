# PostgreSQL (DigitalOcean: use pooled URL for serverless, e.g. ?pgbouncer=true&connection_limit=1)
DATABASE_URL="postgresql://user:password@host:25060/db?sslmode=require&pgbouncer=true&connection_limit=1"

NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Optional: email yang otomatis dijadikan admin setiap kali login (setelah itu bisa dihapus dari .env).
ADMIN_EMAIL=""

AZURE_STORAGE_CONNECTION_STRING=""
AZURE_CONTAINER_NAME="receipts"
